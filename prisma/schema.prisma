generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(cuid())
  clerkId               String            @unique
  email                 String            @unique
  name                  String?
  createdAt             DateTime          @default(now())
  completedOnboardingAt DateTime?         // for onboarding email sequence
  notificationEmail     Boolean           @default(true)
  notificationPush      Boolean           @default(false)
  notificationTime      String?           // e.g. "09:00" for preferred daily time
  subscription          Subscription?
  household             Household?
  pushSubscriptions     PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Household {
  id          String       @id @default(cuid())
  showTitle   String       // e.g. "Life with Biscuit"
  showStyle   String[]     // e.g. ["The Office", "Parks and Rec"]
  comedyNotes String?      // user free-text about their vibe
  ownerName   String?      // your name (the co-star) for script context
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dogs        Dog[]
  castMembers CastMember[]
  episodes    Episode[]
  createdAt   DateTime     @default(now())
}

model Dog {
  id                   String    @id @default(cuid())
  name                 String
  breed                String?
  personality          String[]  // e.g. ["chaotic", "foodie", "dramatic"]
  characterBio         String?   // free-text quirks & behavior for script
  photoUrl             String
  animatedAvatar       String?   // generated Pixar-style avatar URL
  loraId               String?   // Astria tune_id for LoRA (trained from dog photos)
  avatarRegenCount     Int       @default(0) // total regenerations (free: 3 max)
  avatarRegenMonth     String?   // "YYYY-MM" for Pro monthly count
  avatarRegenCountInMonth Int    @default(0) // Pro: regenerations this month
  voiceId              String?   // ElevenLabs voice ID (assigned after first generation)
  householdId          String
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt            DateTime  @default(now())
}

model CastMember {
  id                   String    @id @default(cuid())
  name                 String
  role                 String    // e.g. "Owner", "Roommate", "Kid", "Partner"
  photoUrl             String
  animatedAvatar       String?
  avatarRegenCount     Int       @default(0)
  avatarRegenMonth     String?
  avatarRegenCountInMonth Int    @default(0)
  voiceId              String?   // ElevenLabs voice ID (assigned after first generation)
  householdId          String
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt            DateTime  @default(now())
}

model Episode {
  id                String    @id @default(cuid())
  title             String
  episodeNum        Int
  season            Int       @default(1)
  synopsis          String
  script            Json      // full structured script
  videoUrl          String?   // primary (vertical 1080x1920 for Reels)
  videoUrlLandscape String?   // landscape 1920x1080
  thumbnailUrl      String?
  status            String    @default("generating") // generating | ready | failed
  householdId       String
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  situation         EpisodeSituation?
  createdAt         DateTime  @default(now())
  publishedAt       DateTime?
}

model EpisodeSituation {
  id         String   @id @default(cuid())
  episodeId  String   @unique
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  category   String   // "home" | "outdoor" | "social" | "seasonal" | "emotional"
  situation  String   // e.g. "vet_visit", "squirrel_chase"
  setting    String   // e.g. "living room", "dog park"
  plotDevice String   // e.g. "dog steals thanksgiving turkey"
  tags       String[] // searchable tags
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       String   // "free" | "pro" | "family"
  stripeId   String?
  status     String   // "active" | "canceled" | "past_due"
  renewsAt   DateTime?
  createdAt  DateTime @default(now())
}

model PreviewGeneration {
  id                 String    @id @default(cuid())
  jobId              String    @unique // for polling
  ip                 String?   // rate limit tracking
  dogName            String
  photoUrls          String[]  // up to 3
  userVideoUrl       String?   // optional uploaded video
  avatarUrl          String?   // Replicate Pixar-style output
  comedyStyle        String?   // e.g. "The Office"
  trailerUrl         String?   // final 30s trailer
  status             String   @default("pending") // pending | processing | completed | failed
  errorMessage       String?
  convertedToAccount Boolean   @default(false)
  styleImages        Json?     // { liveAction, cinematicCG, anime, watercolor, comicBook, storybook, pixelArt } from generate-styles
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
}

// Cache for style animation clips (fal Kling) so we don't re-generate on same style card
model PreviewStyleClipCache {
  id              String   @id @default(cuid())
  styleImageUrl   String   // normalized URL
  artStyle        String   // e.g. "Watercolor"
  clips           Json     // { rotation, running, barking, wagging, jumping, headTilt } URLs
  createdAt       DateTime @default(now())
  @@unique([styleImageUrl, artStyle])
}
